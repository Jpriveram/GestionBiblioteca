function cargarAutoresActivosCrear() {
    const optionsContainer = document.querySelector('#custom-select-autor-create .select-options');
    if (!optionsContainer) return;

    fetch(`${window.location.pathname}?handler=AutoresActivos`, {
        headers: { "X-Requested-With": "XMLHttpRequest" }
    })
        .then(response => response.ok ? response.json() : [])
        .then(autores => {
            optionsContainer.innerHTML = "";

            (autores || []).sort((a, b) => (a.displayText || "").localeCompare(b.displayText || "", 'es', { sensitivity: 'base' })).forEach(autor => {
                 const option = document.createElement("div");
                 option.className = "option";
                 option.dataset.value = autor.id;
                 option.textContent = autor.displayText || `${autor.nombres || ""} ${autor.apellidos || ""}`.trim();
                 optionsContainer.appendChild(option);
            });
        })
        .catch(() => { });
}

function mostrarModalEditar() {
    document.getElementById("modalEditar").style.display = "flex";
}

function setValueIfExists(id, value) {
    const element = document.getElementById(id);
    if (element) element.value = value;
}

