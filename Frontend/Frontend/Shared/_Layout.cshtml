<script src="~/lib/jquery/dist/jquery.min.js"></script>
<script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
<script src="~/js/site.js" asp-append-version="true"></script>

@await RenderSectionAsync("Scripts", required: false)
<script>
    var primerInicioForzado = @(debeCambiarPassword ? "true" : "false");
    var cambioPasswordExitoVisible = @(changePasswordOkVisible ? "true" : "false");

    function abrirModalLogin() {
        var modal = document.getElementById("modalLogin");
        if (modal) {
            modal.style.display = "flex";
        }
    }

    function cerrarModalLogin() {
        var modal = document.getElementById("modalLogin");
        if (modal) {
            modal.style.display = "none";
        }
    }

    function abrirModalCambiarPassword() {
        var modal = document.getElementById("modalCambiarPassword");
        if (modal) {
            modal.style.display = "flex";
        }
    }

    function cerrarModalCambiarPassword() {
        if (primerInicioForzado) {
            return;
        }

        var modal = document.getElementById("modalCambiarPassword");
        if (modal) {
            modal.style.display = "none";
        }
    }

    function abrirModalCambioPasswordExito() {
        var modal = document.getElementById("modalCambioPasswordExito");
        if (modal) {
            modal.style.display = "flex";
        }
    }

    function cerrarModalCambioPasswordExito() {
        var modal = document.getElementById("modalCambioPasswordExito");
        if (modal) {
            modal.style.display = "none";
        }
    }

    function togglePasswordLogin() {
        var input = document.getElementById("loginPassword");
        var icon = document.getElementById("togglePasswordIcon");

        if (!input || !icon) return;

        if (input.type === "password") {
            input.type = "text";
            icon.src = "/assets/icons/visibility_off_24dp_E3E3E3_FILL0_wght400_GRAD0_opsz24.svg";
        } else {
            input.type = "password";
            icon.src = "/assets/icons/visibility_24dp_E3E3E3_FILL0_wght400_GRAD0_opsz24.svg";
        }
    }

    function togglePasswordField(inputId, iconId) {
        var input = document.getElementById(inputId);
        var icon = document.getElementById(iconId);

        if (!input || !icon) return;

        if (input.type === "password") {
            input.type = "text";
            icon.src = "/assets/icons/visibility_off_24dp_E3E3E3_FILL0_wght400_GRAD0_opsz24.svg";
        } else {
            input.type = "password";
            icon.src = "/assets/icons/visibility_24dp_E3E3E3_FILL0_wght400_GRAD0_opsz24.svg";
        }
    }

    function mostrarErrorLogin(mensaje) {
        var box = document.getElementById("mensajeLoginModal");
        if (!box) return;

        box.textContent = mensaje;
        box.style.display = "block";

        clearTimeout(box._hideTimer);
        box._hideTimer = setTimeout(function () {
            box.style.display = "none";
            box.textContent = "";
        }, 3500);
    }

    function mostrarErrorCambiarPassword(mensaje) {
        var box = document.getElementById("mensajeCambiarPasswordModal");
        if (!box) return;

        box.textContent = mensaje;
        box.style.display = "block";
    }

    function ocultarErrorCambiarPassword() {
        var box = document.getElementById("mensajeCambiarPasswordModal");
        if (!box) return;

        box.style.display = "none";
        box.textContent = "";
        box.style.whiteSpace = "normal";
    }

    function mostrarErrorCampo(campoId, mensaje) {
        var box = document.getElementById(campoId);
        if (!box) return;

        if (!mensaje) {
            box.style.display = "none";
            box.textContent = "";
            return;
        }

        box.textContent = mensaje;
        box.style.display = "block";
    }

    function limpiarErroresCamposPassword() {
        mostrarErrorCampo("errorPasswordActualModal", "");
        mostrarErrorCampo("errorPasswordNuevaModal", "");
        mostrarErrorCampo("errorPasswordConfirmacionModal", "");
    }

    function establecerEstadoVerificacion(passwordVerificada) {
        var nueva = document.getElementById("passwordNuevaModal");
        var confirmacion = document.getElementById("passwordConfirmacionModal");
        var submit = document.getElementById("btnActualizarPasswordModal");

        if (nueva) nueva.disabled = !passwordVerificada;
        if (confirmacion) confirmacion.disabled = !passwordVerificada;
        if (submit) submit.disabled = !passwordVerificada;
    }

    async function verificarPasswordActual() {
        var inputActual = document.getElementById("passwordActualModal");
        var token = document.querySelector('#formCambiarPasswordModal input[name="__RequestVerificationToken"]');
        var valor = inputActual ? (inputActual.value || "").trim() : "";

        limpiarErroresCamposPassword();
        ocultarErrorCambiarPassword();

        if (!valor) {
            mostrarErrorCampo("errorPasswordActualModal", "Debes ingresar la contraseña actual.");
            establecerEstadoVerificacion(false);
            return;
        }

        try {
            var response = await fetch("/Login?handler=VerificarPasswordActual", {
                method: "POST",
                headers: {
                    "RequestVerificationToken": token ? token.value : "",
                    "Content-Type": "application/x-www-form-urlencoded; charset=UTF-8"
                },
                body: new URLSearchParams({ passwordActualModal: valor })
            });

            var payload = await response.json().catch(function () { return null; });

            if (!response.ok) {
                var mensaje = (payload && payload.message) ? payload.message : "La contraseña actual no es correcta.";
                mostrarErrorCampo("errorPasswordActualModal", mensaje);
                establecerEstadoVerificacion(false);
                return;
            }

            establecerEstadoVerificacion(true);
        } catch (error) {
            mostrarErrorCampo("errorPasswordActualModal", "No se pudo verificar la contraseña actual.");
            establecerEstadoVerificacion(false);
        }
    }

    function limpiarErrorCambiarPassword() {
        var box = document.getElementById("mensajeCambiarPasswordModal");
        if (!box) return;

        box.style.display = "none";
        box.textContent = "";
        box.style.whiteSpace = "normal";
    }

    function validarPasswordSegura(password) {
        var errores = [];

        if (password.length < 8) {
            errores.push("Mínimo 8 caracteres");
        }

        if (!/[A-Z]/.test(password)) {
            errores.push("Al menos 1 mayúscula");
        }

        if (!/[a-z]/.test(password)) {
            errores.push("Al menos 1 minúscula");
        }

        if (!/[0-9]/.test(password)) {
            errores.push("Al menos 1 número");
        }

        if (!/[^a-zA-Z0-9]/.test(password)) {
            errores.push("Al menos 1 carácter especial");
        }

        return errores;
    }

    function mostrarRequisitosPassword(mensajes) {
        var box = document.getElementById("mensajeCambiarPasswordModal");
        if (!box) return;

        if (!mensajes || !mensajes.length) {
            box.style.display = "none";
            box.textContent = "";
            box.style.whiteSpace = "normal";
            return;
        }

        box.textContent = "La nueva contraseña no cumple:\n- " + mensajes.join("\n- ");
        box.style.display = "block";
        box.style.whiteSpace = "pre-line";
    }

    document.addEventListener("DOMContentLoaded", function () {
        var form = document.getElementById("formLoginModal");
        var usuario = document.getElementById("loginNombreUsuario");
        var password = document.getElementById("loginPassword");
        var mensajeServidor = document.getElementById("mensajeLoginServidor");

        if (mensajeServidor) {
            abrirModalLogin();
        }

        var formCambiarPassword = document.getElementById("formCambiarPasswordModal");
        var passwordActualModal = document.getElementById("passwordActualModal");
        var passwordNuevaModal = document.getElementById("passwordNuevaModal");
        var passwordConfirmacionModal = document.getElementById("passwordConfirmacionModal");
        var mensajeCambiarPasswordServidor = document.getElementById("mensajeCambiarPasswordServidor");
        var modalCambiarPassword = document.getElementById("modalCambiarPassword");
        var modalLogin = document.getElementById("modalLogin");

        establecerEstadoVerificacion(false);

        if (modalCambiarPassword) {
            modalCambiarPassword.addEventListener("pointerdown", function (e) {
                modalCambiarPassword._backdropPointerDown = (e.target === modalCambiarPassword);
            });

            modalCambiarPassword.addEventListener("pointerup", function (e) {
                if (modalCambiarPassword._backdropPointerDown && e.target === modalCambiarPassword) {
                    cerrarModalCambiarPassword();
                }

                modalCambiarPassword._backdropPointerDown = false;
            });

            modalCambiarPassword.addEventListener("pointercancel", function () {
                modalCambiarPassword._backdropPointerDown = false;
            });
        }

        if (modalLogin) {
            modalLogin.addEventListener("pointerdown", function (e) {
                modalLogin._backdropPointerDown = (e.target === modalLogin);
            });

            modalLogin.addEventListener("pointerup", function (e) {
                if (modalLogin._backdropPointerDown && e.target === modalLogin) {
                    cerrarModalLogin();
                }

                modalLogin._backdropPointerDown = false;
            });

            modalLogin.addEventListener("pointercancel", function () {
                modalLogin._backdropPointerDown = false;
            });
        }

        if (primerInicioForzado || mensajeCambiarPasswordServidor) {
            abrirModalCambiarPassword();
        }

        if (cambioPasswordExitoVisible) {
            abrirModalCambioPasswordExito();
        }

        function limpiarMensajes() {
            var box = document.getElementById("mensajeLoginModal");
            if (box) {
                box.style.display = "none";
                box.textContent = "";
            }

            if (mensajeServidor) {
                mensajeServidor.style.display = "none";
            }
        }

        if (usuario) usuario.addEventListener("input", limpiarMensajes);
        if (password) password.addEventListener("input", limpiarMensajes);

        if (form) {
            form.addEventListener("submit", function (e) {
                if (!usuario.value.trim()) {
                    e.preventDefault();
                    mostrarErrorLogin("Debes ingresar el nombre de usuario.");
                    usuario.focus();
                    return;
                }

                if (!password.value.trim()) {
                    e.preventDefault();
                    mostrarErrorLogin("Debes ingresar la contraseña.");
                    password.focus();
                    return;
                }
            });
        }

        if (formCambiarPassword) {
            formCambiarPassword.addEventListener("submit", function (e) {
                var actual = (passwordActualModal && passwordActualModal.value ? passwordActualModal.value : "").trim();
                var nueva = (passwordNuevaModal && passwordNuevaModal.value ? passwordNuevaModal.value : "").trim();
                var confirmacion = (passwordConfirmacionModal && passwordConfirmacionModal.value ? passwordConfirmacionModal.value : "").trim();

                if (!passwordNuevaModal || passwordNuevaModal.disabled) {
                    e.preventDefault();
                    mostrarErrorCampo("errorPasswordActualModal", "Primero verifica la contraseña actual.");
                    return;
                }

                if (!actual || !nueva || !confirmacion) {
                    e.preventDefault();
                    if (!actual) {
                        mostrarErrorCampo("errorPasswordActualModal", "Debes ingresar la contraseña actual.");
                    }
                    if (!nueva) {
                        mostrarErrorCampo("errorPasswordNuevaModal", "Debes ingresar la nueva contraseña.");
                    }
                    if (!confirmacion) {
                        mostrarErrorCampo("errorPasswordConfirmacionModal", "Debes confirmar la nueva contraseña.");
                    }
                    return;
                }

                if (nueva !== confirmacion) {
                    e.preventDefault();
                    mostrarErrorCampo("errorPasswordConfirmacionModal", "La nueva contraseña y su confirmación no coinciden.");
                    return;
                }

                var erroresPassword = validarPasswordSegura(nueva);

                if (erroresPassword.length > 0) {
                    e.preventDefault();
                    mostrarErrorCampo("errorPasswordNuevaModal", "La nueva contraseña no cumple: " + erroresPassword.join(", "));
                    return;
                }

                ocultarErrorCambiarPassword();
                limpiarErroresCamposPassword();
            });

            if (passwordNuevaModal) {
                passwordNuevaModal.addEventListener("input", function () {
                    var nueva = (passwordNuevaModal.value || "").trim();
                    var erroresPassword = validarPasswordSegura(nueva);

                    if (!nueva) {
                        mostrarErrorCampo("errorPasswordNuevaModal", "");
                        return;
                    }

                    if (passwordNuevaModal.disabled === false) {
                        mostrarErrorCampo("errorPasswordNuevaModal", erroresPassword.length > 0 ? "La nueva contraseña no cumple: " + erroresPassword.join(", ") : "");
                    }
                });
            }

            if (passwordActualModal) {
                passwordActualModal.addEventListener("input", function () {
                    establecerEstadoVerificacion(false);
                    limpiarErroresCamposPassword();
                });

                passwordActualModal.addEventListener("blur", function () {
                    if ((passwordActualModal.value || "").trim()) {
                        verificarPasswordActual();
                    }
                });

                passwordActualModal.addEventListener("keydown", function (e) {
                    if (e.key === "Enter") {
                        e.preventDefault();
                        verificarPasswordActual();
                    }
                });
            }

            if (passwordConfirmacionModal) {
                passwordConfirmacionModal.addEventListener("input", function () {
                    var nueva = (passwordNuevaModal && passwordNuevaModal.value ? passwordNuevaModal.value : "").trim();
                    var confirmacion = (passwordConfirmacionModal.value || "").trim();

                    if (!nueva || !confirmacion) {
                        mostrarErrorCampo("errorPasswordConfirmacionModal", "");
                        return;
                    }

                    if (nueva !== confirmacion) {
                        mostrarErrorCampo("errorPasswordConfirmacionModal", "La nueva contraseña y su confirmación no coinciden.");
                    } else {
                        mostrarErrorCampo("errorPasswordConfirmacionModal", "");
                    }
                });
            }
        }

        establecerEstadoVerificacion(false);
    });

    window.addEventListener("click", function (e) {
        var modalCambioPasswordExito = document.getElementById("modalCambioPasswordExito");
        if (modalCambioPasswordExito && e.target === modalCambioPasswordExito) {
            cerrarModalCambioPasswordExito();
        }
    });

    window.addEventListener("pageshow", function (event) {
    var navigation = performance.getEntriesByType("navigation")[0];

    var vieneDeAtras =
        event.persisted ||
        (navigation && navigation.type === "back_forward");

    if (vieneDeAtras) {
        window.location.reload();
    }
});
</script>

</body>
</html>
