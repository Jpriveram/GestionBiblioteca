@section Scripts {
<script>
    function abrirModalDetalle(
    autor, titulo, isbn, editorial, genero, edicion,
    anio, paginas, idioma, pais, descripcion,
    fechaRegistroIso, ultimaActualizacionIso
){
    document.getElementById("dAutor").textContent = autor || "N/A";
    document.getElementById("dTitulo").textContent = titulo || "N/A";
    document.getElementById("dISBN").textContent = isbn || "N/A";
    document.getElementById("dEditorial").textContent = editorial || "N/A";
    document.getElementById("dGenero").textContent = genero || "N/A";
    document.getElementById("dEdicion").textContent = edicion || "N/A";
    document.getElementById("dAnio").textContent = anio || "N/A";
    document.getElementById("dPaginas").textContent = paginas || "N/A";
    document.getElementById("dIdioma").textContent = idioma || "N/A";
    document.getElementById("dPais").textContent = pais || "N/A";
    document.getElementById("dDescripcion").textContent = descripcion || "N/A";

    // mostrar fechas en hora local usando el navegador
    try {
        document.getElementById("dFechaRegistro").textContent = formatearFecha(fechaRegistroIso, true);
    } catch { document.getElementById("dFechaRegistro").textContent = "N/A"; }

    try {
        document.getElementById("dUltimaActualizacion").textContent = ultimaActualizacionIso ? formatearFecha(ultimaActualizacionIso, true) : "N/A";
    } catch { document.getElementById("dUltimaActualizacion").textContent = "N/A"; }

    document.getElementById("modalDetalle").style.display = "flex";
}

    function formatearFecha(fechaIso, incluirHora = true) {
        if (!fechaIso) return 'No registrado';
        const valor = new Date(fechaIso);
        return incluirHora ? valor.toLocaleString() : valor.toLocaleDateString();
    }

function cerrarModalDetalle(){
    document.getElementById("modalDetalle").style.display = "none";
}

(function () {
    var input = document.getElementById('buscador-libro');
    var select = document.getElementById('orden-libro');
    var tabla = document.getElementById('tabla-libro');

    if (!input || !tabla) return;

    function normalizar(s) {
        return (s || '').normalize('NFD').replace(/[\u0300-\u036f]/g, '').toLowerCase().trim();
    }

    function aplicar() {
        var termino = normalizar(input.value);
        var orden = select ? select.value : 'titulo_asc';
        var tbody = tabla.querySelector('tbody');
        var filas = Array.from(tbody.querySelectorAll('tr:not(#fila-sin-resultados)'));
        var asc = orden.endsWith('_asc');

        filas.sort(function (a, b) {
            var va = normalizar(a.cells[0].textContent);
            var vb = normalizar(b.cells[0].textContent);
            return asc ? va.localeCompare(vb) : vb.localeCompare(va);
        });

        filas.forEach(function (f) { tbody.appendChild(f); });
        var visibles = 0;

        filas.forEach(function (fila) {
            var texto = normalizar(fila.textContent);
            var coincide = termino === '' || texto.includes(termino);
            fila.style.display = coincide ? '' : 'none';
            if (coincide) visibles++;
        });

        var sinResultados = document.getElementById('fila-sin-resultados');
        if (sinResultados) {
            sinResultados.style.display = visibles === 0 ? '' : 'none';
            tbody.appendChild(sinResultados);
        }
    }

    input.addEventListener('input', aplicar);
    if (select) select.addEventListener('change', aplicar);
    aplicar();
})();

function decodificarHtml(texto) {
    if (!texto) return "";
    const txt = document.createElement("textarea");
    txt.innerHTML = texto;
    return txt.value;
}

function permitirSoloIsbn(id) {
    const input = document.getElementById(id);
    if (!input) return;

    input.addEventListener('input', function() {
        this.value = this.value.replace(/[^0-9\-X]/gi, '').toUpperCase();
    });

    input.addEventListener('keypress', function(e) {
        const char = String.fromCharCode(e.which);
        if (!/[0-9\-X]/.test(char)) {
            e.preventDefault();
        }
    });
}

function filtrarCaracteresEspeciales(id) {
    const input = document.getElementById(id);
    if (!input) return;

    input.addEventListener('input', function() {
        // Solo permite letras (incluyendo acentos), números, espacios y guiones
        this.value = this.value.replace(/[^a-záéíóúñüA-ZÁÉÍÓÚÑÜ0-9\s\-]/g, '');
    });

    input.addEventListener('keypress', function(e) {
        const char = String.fromCharCode(e.which);
        // Permitir letras, números, espacios, guiones y algunos caracteres especiales válidos
        if (!/[a-záéíóúñüA-ZÁÉÍÓÚÑÜ0-9\s\-]/.test(char)) {
            e.preventDefault();
        }
    });
}

function filtrarDescripcion(id) {
    const textarea = document.getElementById(id);
    if (!textarea) return;

    textarea.addEventListener('input', function() {
        // Permitir letras (acentos), números, espacios, guiones, puntos, comas y saltos de línea
        this.value = this.value.replace(/[^a-záéíóúñüA-ZÁÉÍÓÚÑÜ0-9\s\-.,\n]/g, '');
    });
}

function sincronizarCamposCrear() {
    const autorSelect = document.getElementById('custom-select-autor-create');
    const autorSearchInput = document.getElementById('createAutorText');
    const tituloSearchInput = document.getElementById('createTituloText');
    const generoSelect = document.getElementById('custom-select-genero-create');
    const generoSearchInput = document.getElementById('createGeneroText');
    const idiomaSelect = document.getElementById('custom-select-idioma-create');
    const idiomaSearchInput = document.getElementById('idioma-search-create');
    const paisSelect = document.getElementById('custom-select-pais-create');
    const paisSearchInput = document.getElementById('pais-search-create');

    const createAutorId = document.getElementById('createAutorId');
    const createAutorNuevo = document.getElementById('createAutorNuevo');
    const createGeneroHidden = document.getElementById('createGeneroHidden');
    const createIdiomaHidden = document.getElementById('createIdiomaHidden');
    const createPaisPublicacionHidden = document.getElementById('createPaisPublicacionHidden');

    if (autorSearchInput && autorSearchInput.value.trim() && !createAutorId.value) {
        createAutorNuevo.value = autorSearchInput.value.trim();
    }

    if (generoSearchInput && generoSearchInput.value.trim()) {
        createGeneroHidden.value = generoSearchInput.value.trim();
    }

    if (idiomaSearchInput && idiomaSearchInput.value.trim()) {
        createIdiomaHidden.value = idiomaSearchInput.value.trim();
    }

    // El pais solo se toma de la lista (no se acepta texto libre)

    // Sincronizar estado del checkbox
    const estadoCheckbox = document.getElementById('createEstadoActivo');
    if (estadoCheckbox) {
        const estadoInput = document.querySelector('input[name="Estado"]');
        if (estadoInput) {
            estadoInput.value = estadoCheckbox.checked ? 'true' : 'false';
        }
    }

    // Trim de campos de texto
    const campos = ['createISBN', 'createEditorial', 'createAnioPublicacion', 'createNumeroPaginas', 'createDescripcion'];
