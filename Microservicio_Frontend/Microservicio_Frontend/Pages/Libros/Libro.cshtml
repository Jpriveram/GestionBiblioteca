function enviarFormularioCrearAjax(formulario) {
    const formData = new FormData(formulario);
    const errorSummary = document.getElementById('error-summary-create');

    fetch(formulario.action, {
        method: 'POST',
        body: formData,
        headers: {
            'X-Requested-With': 'XMLHttpRequest'
        }
    })
    .then(response => response.json())
    .then(data => {
        if (data.success) {
            cerrarModalCrear();
            location.reload();
        } else {
            mostrarErroresCrear(data.errors);
        }
    })
    .catch(error => {
        console.error('Error:', error);
        errorSummary.style.display = 'block';
        errorSummary.innerHTML = '<p>Error al procesar la solicitud</p>';
    });
}

