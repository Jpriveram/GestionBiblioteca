@page "/Autor"
@using System.Linq
@model Frontend.Pages.AutorModel
@{
    ViewData["Title"] = "Gestión de Autores";

    var paises = new List<string>
    {
        "Argentina", "Bolivia", "Brasil", "Chile", "Colombia", "Costa Rica", "Cuba",
        "Ecuador", "El Salvador", "Guatemala", "Honduras", "México", "Nicaragua",
        "Panamá", "Paraguay", "Perú", "República Dominicana", "Uruguay", "Venezuela",
        "Estados Unidos", "Canadá", "España", "Francia", "Alemania", "Italia",
        "Reino Unido", "Irlanda", "Portugal", "Países Bajos", "Bélgica", "Suiza",
        "Austria", "Suecia", "Noruega", "Dinamarca", "Finlandia", "Polonia",
        "Hungría", "República Checa", "Eslovaquia", "Rusia", "Ucrania", "Grecia",
        "Turquía", "Rumania", "Bulgaria", "Serbia", "China", "Japón",
        "Corea del Sur", "Corea del Norte", "India", "Pakistán", "Bangladés",
        "Indonesia", "Tailandia", "Vietnam", "Filipinas", "Malasia", "Singapur",
        "Arabia Saudita", "Emiratos Árabes Unidos", "Israel", "Irán", "Irak",
        "Qatar", "Kuwait", "Egipto", "Marruecos", "Argelia", "Túnez",
        "Sudáfrica", "Nigeria", "Kenia", "Etiopía", "Ghana", "Senegal",
        "Camerún", "Costa de Marfil", "Australia", "Nueva Zelanda", "Fiyi"
    };

    string editToken = ViewData.ModelState.ContainsKey("token")
        ? ViewData.ModelState["token"]?.AttemptedValue ?? ""
        : "";

    string editNombres = ViewData.ModelState.ContainsKey("Nombres")
        ? ViewData.ModelState["Nombres"]?.AttemptedValue ?? ""
        : "";

    string editApellidos = ViewData.ModelState.ContainsKey("Apellidos")
        ? ViewData.ModelState["Apellidos"]?.AttemptedValue ?? ""
        : "";

    string editNacionalidad = ViewData.ModelState.ContainsKey("Nacionalidad")
        ? ViewData.ModelState["Nacionalidad"]?.AttemptedValue ?? ""
        : "";

    string editFechaNacimiento = ViewData.ModelState.ContainsKey("FechaNacimiento")
        ? ViewData.ModelState["FechaNacimiento"]?.AttemptedValue ?? ""
        : "";

    string createNombres = ViewData.ModelState.ContainsKey("AutorDto.Nombres")
        ? ViewData.ModelState["AutorDto.Nombres"]?.AttemptedValue ?? ""
        : "";

    string createApellidos = ViewData.ModelState.ContainsKey("AutorDto.Apellidos")
        ? ViewData.ModelState["AutorDto.Apellidos"]?.AttemptedValue ?? ""
        : "";

    string createNacionalidad = ViewData.ModelState.ContainsKey("AutorDto.Nacionalidad")
        ? ViewData.ModelState["AutorDto.Nacionalidad"]?.AttemptedValue ?? ""
        : "";

    string createFechaNacimiento = ViewData.ModelState.ContainsKey("AutorDto.FechaNacimiento")
        ? ViewData.ModelState["AutorDto.FechaNacimiento"]?.AttemptedValue ?? ""
        : "";

    string ErrorCampo(string key)
    {
        return ViewData.ModelState.ContainsKey(key)
            ? ViewData.ModelState[key]?.Errors.FirstOrDefault()?.ErrorMessage ?? ""
            : "";
    }
}

@section Styles {
    <link rel="stylesheet" href="~/css/pages/Autores.css" />
}

<div class="autores-container">

    <div class="page-header">
        <div class="titulo-logo">
            <h1>Gestión de Autores</h1>
        </div>

        <button type="button" class="btn-nuevo" onclick="abrirModalCrear()">
            <img src="~/assets/icons/add_24dp_E3E3E3_FILL0_wght400_GRAD0_opsz24.svg" class="icono-btn">
            Nuevo Autor
        </button>
    </div>

    <div class="filtros-barra">
        <div class="filtro-item filtro-buscar">
            <input id="buscador-autor"
                   type="text"
                   class="input-filtro"
                   placeholder="Buscar..."
                   autocomplete="off" />
        </div>
    </div>

    <div class="tabla-container">
        <table id="tabla-autores" class="tabla-autores">
            <thead>
                <tr>
                    <th>Nombres</th>
                    <th>Apellidos</th>
                    <th>Nacionalidad</th>
                    <th>Fecha</th>
                    <th>Estado</th>
                    <th>Acciones</th>
                </tr>
            </thead>

            <tbody>
                @foreach (var autor in Model.Autores)
                {
                    var token = autor.RouteToken;
                    var nombres = autor.Nombres ?? "";
                    var apellidos = autor.Apellidos ?? "";
                    var nombresDisplay = nombres.Trim().ToDisplayName();
                    var apellidosDisplay = apellidos.Trim().ToDisplayName();
                    var nacionalidad = autor.Nacionalidad ?? "";
                    var fecha = autor.FechaNacimiento?.ToString("yyyy-MM-dd") ?? "";
                    var estado = autor.Estado;

                    <tr>
                        <td>@nombresDisplay</td>
                        <td>@apellidosDisplay</td>
                        <td>@nacionalidad</td>
                        <td>@(string.IsNullOrWhiteSpace(fecha) ? "Sin fecha" : fecha)</td>

                        <td>
                            @if (estado)
                            {
                                <span class="estado activo">Activo</span>
                            }
                            else
                            {
                                <span class="estado inactivo">Inactivo</span>
                            }
                        </td>

                        <td class="acciones">
                            <button type="button"
                                    class="btn-editar"
                                    onclick="abrirModalEditar(
                                        '@token',
                                        '@Html.Raw(nombres.Replace("'", "\\'"))',
                                        '@Html.Raw(apellidos.Replace("'", "\\'"))',
                                        '@Html.Raw(nacionalidad.Replace("'", "\\'"))',
                                        '@fecha'
                                    )">
                                <img src="~/assets/icons/edit_24dp_E3E3E3_FILL0_wght400_GRAD0_opsz24.svg"
                                     class="icono-btn">
                                Editar
                            </button>

                            @if (estado)
                            {
                                <button type="button"
                                        class="btn-eliminar"
                                        onclick="abrirModal('@token')">
                                    <img src="~/assets/icons/delete_24dp_E3E3E3_FILL0_wght400_GRAD0_opsz24.svg"
                                         class="icono-btn">
                                    Eliminar
                                </button>
                            }
                            else
                            {
                                <span class="estado eliminado-label">Eliminado</span>
                            }
                        </td>
                    </tr>
                }

                <tr id="fila-sin-resultados" style="display:none;">
                    <td colspan="6" style="text-align:center; padding:20px; color:#9ca3af;">
                        No hay autores que coincidan con la búsqueda.
                    </td>
                </tr>
            </tbody>
        </table>
    </div>
</div>

<div id="modalEliminar" class="modal">
    <div class="modal-box modal-box-small">

        <div class="modal-icon">
            <img src="~/assets/icons/delete_24dp_E3E3E3_FILL0_wght400_GRAD0_opsz24.svg"
                 class="icono-modal">
        </div>

        <h2>¿Eliminar autor?</h2>
        <p>No se puede deshacer.</p>

        <form method="post" asp-page-handler="Eliminar">
            @Html.AntiForgeryToken()
            <input type="hidden" id="autorTokenInput" name="token" />

            <div class="modal-buttons">
                <button type="submit" class="btn-danger">Eliminar</button>
                <button type="button" class="btn-secondary" onclick="cerrarModal()">Cancelar</button>
            </div>
        </form>
    </div>
</div>

<div id="modalEditar" class="modal">
    <div class="modal-box">
        <h2>Editar Autor</h2>

        <form method="post" asp-page-handler="Editar" id="editAutorForm" novalidate>
            @Html.AntiForgeryToken()

            <input type="hidden" id="editToken" name="token" value="@editToken" />

            <input type="text"
                   id="editNombres"
                   name="Nombres"
                   placeholder="Nombres"
                   value="@editNombres"
                   data-field="editNombres" />
            <span class="text-error field-error"
                  id="error-editNombres"
                  style="display:@(!string.IsNullOrWhiteSpace(ErrorCampo("Nombres")) ? "block" : "none")">
                @ErrorCampo("Nombres")
            </span>

            <input type="text"
                   id="editApellidos"
                   name="Apellidos"
                   placeholder="Apellidos opcional"
                   value="@editApellidos"
                   data-field="editApellidos" />
            <span class="text-error field-error"
                  id="error-editApellidos"
                  style="display:@(!string.IsNullOrWhiteSpace(ErrorCampo("Apellidos")) ? "block" : "none")">
                @ErrorCampo("Apellidos")
            </span>

            <select id="editNacionalidad" name="Nacionalidad" data-field="editNacionalidad">
                <option value="">Nacionalidad opcional</option>
                @foreach (var pais in paises)
                {
                    <option value="@pais" selected="@(editNacionalidad == pais ? "selected" : null)">
                        @pais
                    </option>
                }
            </select>
            <span class="text-error field-error"
                  id="error-editNacionalidad"
                  style="display:@(!string.IsNullOrWhiteSpace(ErrorCampo("Nacionalidad")) ? "block" : "none")">
                @ErrorCampo("Nacionalidad")
            </span>

            <input type="date"
                   id="editFechaNacimiento"
                   name="FechaNacimiento"
                   value="@editFechaNacimiento"
                   data-field="editFechaNacimiento" />
            <span class="text-error field-error"
                  id="error-editFechaNacimiento"
                  style="display:@(!string.IsNullOrWhiteSpace(ErrorCampo("FechaNacimiento")) ? "block" : "none")">
                @ErrorCampo("FechaNacimiento")
            </span>

            <input type="hidden" id="editEstado" name="Estado" value="true" />

            <div class="estado-readonly">
                <span class="estado activo">Activo</span>
            </div>

            <div class="modal-buttons">
                <button type="submit" class="btn-warning">Guardar</button>
                <button type="button" class="btn-secondary" onclick="cerrarModalEditar()">Cancelar</button>
            </div>
        </form>
    </div>
</div>

<div id="modalCrear" class="modal">
    <div class="modal-box">
        <h2>Nuevo Autor</h2>

        <form method="post" asp-page-handler="Crear" id="createAutorForm" novalidate>
            @Html.AntiForgeryToken()

            <input type="text"
                   id="createNombres"
                   name="AutorDto.Nombres"
                   placeholder="Nombres"
                   value="@createNombres"
                   data-field="createNombres" />
            <span class="text-error field-error"
                  id="error-createNombres"
                  style="display:@(!string.IsNullOrWhiteSpace(ErrorCampo("AutorDto.Nombres")) ? "block" : "none")">
                @ErrorCampo("AutorDto.Nombres")
            </span>

            <input type="text"
                   id="createApellidos"
                   name="AutorDto.Apellidos"
                   placeholder="Apellidos opcional"
                   value="@createApellidos"
                   data-field="createApellidos" />
            <span class="text-error field-error"
                  id="error-createApellidos"
                  style="display:@(!string.IsNullOrWhiteSpace(ErrorCampo("AutorDto.Apellidos")) ? "block" : "none")">
                @ErrorCampo("AutorDto.Apellidos")
            </span>

            <select id="createNacionalidad"
                    name="AutorDto.Nacionalidad"
                    data-field="createNacionalidad">
                <option value="">Nacionalidad opcional</option>
                @foreach (var pais in paises)
                {
                    <option value="@pais" selected="@(createNacionalidad == pais ? "selected" : null)">
                        @pais
                    </option>
                }
            </select>
            <span class="text-error field-error"
                  id="error-createNacionalidad"
                  style="display:@(!string.IsNullOrWhiteSpace(ErrorCampo("AutorDto.Nacionalidad")) ? "block" : "none")">
                @ErrorCampo("AutorDto.Nacionalidad")
            </span>

            <input type="date"
                   id="createFechaNacimiento"
                   name="AutorDto.FechaNacimiento"
                   value="@createFechaNacimiento"
                   data-field="createFechaNacimiento" />
            <span class="text-error field-error"
                  id="error-createFechaNacimiento"
                  style="display:@(!string.IsNullOrWhiteSpace(ErrorCampo("AutorDto.FechaNacimiento")) ? "block" : "none")">
                @ErrorCampo("AutorDto.FechaNacimiento")
            </span>

            <input type="hidden" name="AutorDto.Estado" value="true" />

            <div class="estado-readonly">
                <span class="estado activo">Activo</span>
            </div>

            <div class="modal-buttons">
                <button type="submit" class="btn-success">Crear</button>
                <button type="button" class="btn-secondary" onclick="cerrarModalCrear()">Cancelar</button>
            </div>
        </form>
    </div>
</div>

@if (!ViewData.ModelState.IsValid)
{
    <script>
        document.addEventListener("DOMContentLoaded", function () {
            var modalActivo = '@Model.ModalActivo';

            if (modalActivo === "crear") {
                abrirModalCrear(false);
            }

            if (modalActivo === "editar") {
                document.getElementById("modalEditar").style.display = "flex";
            }
        });
    </script>
}

@section Scripts {
    <script>
        function abrirModal(token) {
            document.getElementById("autorTokenInput").value = token;
            modalEliminar.style.display = "flex";
        }

        function cerrarModal() {
            modalEliminar.style.display = "none";
        }

        function abrirModalEditar(t, n, a, na, f) {
            editToken.value = t;
            editNombres.value = formatearNombrePropio(n || "");
            editApellidos.value = formatearNombrePropio(a || "");
            editNacionalidad.value = na || "";
            editFechaNacimiento.value = f || "";
            editEstado.value = "true";

            limpiarErrores(editAutorForm);
            modalEditar.style.display = "flex";
        }

        function cerrarModalEditar() {
            modalEditar.style.display = "none";
        }

        function abrirModalCrear(limpiar = true) {
            if (limpiar) {
                limpiarErrores(createAutorForm);
            }

            modalCrear.style.display = "flex";
        }

        function cerrarModalCrear() {
            modalCrear.style.display = "none";
        }

        const modalBackdropStateAutor = {};

        function bindBackdropCloseAutor(modalId, closeFn) {
            const modal = document.getElementById(modalId);
            if (!modal) return;

            modal.addEventListener("pointerdown", function (e) {
                modalBackdropStateAutor[modalId] = (e.target === modal);
            });

            modal.addEventListener("pointerup", function (e) {
                if (modalBackdropStateAutor[modalId] && e.target === modal) {
                    closeFn();
                }

                modalBackdropStateAutor[modalId] = false;
            });

            modal.addEventListener("pointercancel", function () {
                modalBackdropStateAutor[modalId] = false;
            });
        }

        bindBackdropCloseAutor("modalEliminar", cerrarModal);
        bindBackdropCloseAutor("modalEditar", cerrarModalEditar);
        bindBackdropCloseAutor("modalCrear", cerrarModalCrear);

        function normalizarTexto(valor) {
            return valor.replace(/\s+/g, " ").trim();
        }

        function separarPalabrasPegadasPorMayuscula(valor) {
            return normalizarTexto(valor).replace(/([a-záéíóúñü])([A-ZÁÉÍÓÚÑÜ])/g, "$1 $2");
        }

        function formatearNombrePropio(valor) {
            valor = separarPalabrasPegadasPorMayuscula(valor);

            if (!valor) {
                return "";
            }

            return valor
                .toLowerCase()
                .split(" ")
                .filter(parte => parte.length > 0)
                .map(parte => parte.charAt(0).toUpperCase() + parte.slice(1))
                .join(" ");
        }

        function tieneLetrasSeparadas(valor) {
            const partes = normalizarTexto(valor).split(" ").filter(parte => parte.length > 0);
            return partes.some(parte => parte.length === 1);
        }

        function limpiarErrores(form) {
            if (!form) return;

            form.querySelectorAll(".field-error").forEach(error => {
                error.textContent = "";
                error.style.display = "none";
            });

            form.querySelectorAll("input, select").forEach(campo => {
                campo.classList.remove("input-error");
            });
        }

        function mostrarError(campo, mensaje) {
            const error = document.getElementById("error-" + campo.dataset.field);

            campo.classList.add("input-error");

            if (error) {
                error.textContent = mensaje;
                error.style.display = "block";
            }
        }

        function validarFormularioAutor(form, modo) {
            limpiarErrores(form);

            const nombres = modo === "crear"
                ? document.getElementById("createNombres")
                : document.getElementById("editNombres");

            const apellidos = modo === "crear"
                ? document.getElementById("createApellidos")
                : document.getElementById("editApellidos");

            const nacionalidad = modo === "crear"
                ? document.getElementById("createNacionalidad")
                : document.getElementById("editNacionalidad");

            const fecha = modo === "crear"
                ? document.getElementById("createFechaNacimiento")
                : document.getElementById("editFechaNacimiento");

            nombres.value = formatearNombrePropio(nombres.value);
            apellidos.value = formatearNombrePropio(apellidos.value);

            const soloLetras = /^[a-zA-ZáéíóúÁÉÍÓÚñÑüÜ\s]+$/;

            if (!nombres.value) {
                mostrarError(nombres, "Ingrese el nombre del autor.");
                return false;
            }

            if (!soloLetras.test(nombres.value)) {
                mostrarError(nombres, "El nombre solo debe contener letras y espacios.");
                return false;
            }

            if (tieneLetrasSeparadas(nombres.value)) {
                mostrarError(nombres, "No se permiten letras separadas por espacios.");
                return false;
            }

            if (apellidos.value && !soloLetras.test(apellidos.value)) {
                mostrarError(apellidos, "Los apellidos solo deben contener letras y espacios.");
                return false;
            }

            if (apellidos.value && tieneLetrasSeparadas(apellidos.value)) {
                mostrarError(apellidos, "No se permiten letras separadas por espacios en los apellidos.");
                return false;
            }

            if (nacionalidad.value && !soloLetras.test(nacionalidad.value)) {
                mostrarError(nacionalidad, "La nacionalidad solo debe contener letras y espacios.");
                return false;
            }

            if (nacionalidad.value && tieneLetrasSeparadas(nacionalidad.value)) {
                mostrarError(nacionalidad, "No se permiten letras separadas por espacios en la nacionalidad.");
                return false;
            }

            if (!fecha.value) {
                return true;
            }

            const fechaIngresada = new Date(fecha.value + "T00:00:00");
            const hoy = new Date();
            hoy.setHours(0, 0, 0, 0);

            if (fechaIngresada > hoy) {
                mostrarError(fecha, "La fecha de nacimiento no puede ser futura.");
                return false;
            }

            let edad = hoy.getFullYear() - fechaIngresada.getFullYear();
            const mes = hoy.getMonth() - fechaIngresada.getMonth();

            if (mes < 0 || (mes === 0 && hoy.getDate() < fechaIngresada.getDate())) {
                edad--;
            }

            if (edad < 18) {
                mostrarError(fecha, "El autor debe ser mayor de edad.");
                return false;
            }

            return true;
        }

        document.addEventListener("DOMContentLoaded", function () {
            const createForm = document.getElementById("createAutorForm");
            const editForm = document.getElementById("editAutorForm");

            if (createForm) {
                createForm.addEventListener("submit", function (e) {
                    if (!validarFormularioAutor(createForm, "crear")) {
                        e.preventDefault();
                    }
                });
            }

            if (editForm) {
                editForm.addEventListener("submit", function (e) {
                    if (!validarFormularioAutor(editForm, "editar")) {
                        e.preventDefault();
                    }
                });
            }
        });

        (function () {
            const input = document.getElementById('buscador-autor');
            const tabla = document.getElementById('tabla-autores');
            const filaSinResultados = document.getElementById('fila-sin-resultados');

            if (!input || !tabla) return;

            input.addEventListener('input', function () {
                const filtro = input.value.toLowerCase().trim();
                const filas = tabla.querySelectorAll('tbody tr:not(#fila-sin-resultados)');
                let hayResultados = false;

                filas.forEach(fila => {
                    const textoFila = fila.textContent.toLowerCase();
                    const coincide = textoFila.includes(filtro);

                    fila.style.display = coincide ? "" : "none";

                    if (coincide) {
                        hayResultados = true;
                    }
                });

                if (filaSinResultados) {
                    filaSinResultados.style.display = hayResultados ? "none" : "";
                }
            });
        })();
    </script>
}