@page "/Libro"
@using System.Data
@using System.Linq
@model Frontend.Pages.LibroModel
@{
    ViewData["Title"] = "Gestión de Libros";

    var titulosSugeridos = new HashSet<string>(StringComparer.OrdinalIgnoreCase);
    var generosSugeridos = new HashSet<string>(StringComparer.OrdinalIgnoreCase);
    var paisesSugeridos = new HashSet<string>(StringComparer.OrdinalIgnoreCase);

    // Agregar géneros por defecto
    var generosDefault = new[] { "Ficción", "No Ficción", "Historia", "Ciencia", "Biografía", "Infantil", "Juvenil", "Romance", "Misterio", "Fantasía", "Poesía", "Ensayo" };
    foreach (var generoDefault in generosDefault)
    {
        generosSugeridos.Add(generoDefault);
    }

    // Agregar países por defecto
    var paisesDefault = new[] { "Afganistán", "Albania", "Alemania", "Andorra", "Angola", "Antigua y Barbuda", "Arabia Saudita", "Argelia", "Argentina", "Armenia", "Australia", "Austria", "Azerbaiyán", "Bahamas", "Bangladés", "Barbados", "Baréin", "Bélgica", "Belice", "Benín", "Bielorrusia", "Birmania", "Bolivia", "Bosnia y Herzegovina", "Botsuana", "Brasil", "Brunéi", "Bulgaria", "Burkina Faso", "Burundi", "Bután", "Cabo Verde", "Camboya", "Camerún", "Canadá", "Catar", "Chad", "Chile", "China", "Chipre", "Colombia", "Comoras", "Corea del Norte", "Corea del Sur", "Costa de Marfil", "Costa Rica", "Croacia", "Cuba", "Dinamarca", "Dominica", "Ecuador", "Egipto", "El Salvador", "Emiratos Árabes Unidos", "Eritrea", "Eslovaquia", "Eslovenia", "España", "Estados Unidos", "Estonia", "Esuatini", "Etiopía", "Filipinas", "Finlandia", "Fiyi", "Francia", "Gabón", "Gambia", "Georgia", "Ghana", "Granada", "Grecia", "Guatemala", "Guinea", "Guinea-Bisáu", "Guinea Ecuatorial", "Guyana", "Haití", "Honduras", "Hungría", "India", "Indonesia", "Irak", "Irán", "Irlanda", "Islandia", "Islas Marshall", "Islas Salomón", "Israel", "Italia", "Jamaica", "Japón", "Jordania", "Kazajistán", "Kenia", "Kirguistán", "Kiribati", "Kuwait", "Laos", "Lesoto", "Letonia", "Líbano", "Liberia", "Libia", "Liechtenstein", "Lituania", "Luxemburgo", "Madagascar", "Malasia", "Malaui", "Maldivas", "Malí", "Malta", "Marruecos", "Mauricio", "Mauritania", "México", "Micronesia", "Moldavia", "Mónaco", "Mongolia", "Montenegro", "Mozambique", "Namibia", "Nauru", "Nepal", "Nicaragua", "Níger", "Nigeria", "Noruega", "Nueva Zelanda", "Omán", "Países Bajos", "Pakistán", "Palaos", "Panamá", "Papúa Nueva Guinea", "Paraguay", "Perú", "Polonia", "Portugal", "Reino Unido", "República Centroafricana", "República Checa", "República del Congo", "República Democrática del Congo", "República Dominicana", "Ruanda", "Rumanía", "Rusia", "Samoa", "San Cristóbal y Nieves", "San Marino", "San Vicente y las Granadinas", "Santa Lucía", "Santo Tomé y Príncipe", "Senegal", "Serbia", "Seychelles", "Sierra Leona", "Singapur", "Siria", "Somalia", "Sri Lanka", "Sudáfrica", "Sudán", "Sudán del Sur", "Suecia", "Suiza", "Surinam", "Tailandia", "Tanzania", "Tayikistán", "Timor Oriental", "Togo", "Tonga", "Trinidad y Tobago", "Túnez", "Turkmenistán", "Turquía", "Tuvalu", "Ucrania", "Uganda", "Uruguay", "Uzbekistán", "Vanuatu", "Vaticano", "Venezuela", "Vietnam", "Yemen", "Yibuti", "Zambia", "Zimbabue" };
    foreach (var paisDefault in paisesDefault)
    {
        paisesSugeridos.Add(paisDefault);
    }

    foreach (var row in Model.Libros)
    {
        var tituloTemp = row.Titulo;
        var generoTemp = row.Genero;
        var paisTemp = row.PaisPublicacion;

        if (!string.IsNullOrWhiteSpace(tituloTemp))
            titulosSugeridos.Add(tituloTemp);

        if (!string.IsNullOrWhiteSpace(generoTemp))
            generosSugeridos.Add(generoTemp);

        if (!string.IsNullOrWhiteSpace(paisTemp))
            paisesSugeridos.Add(paisTemp);
    }

    string SoloNombreAutor(string? nombre)
    {
        if (string.IsNullOrWhiteSpace(nombre)) return string.Empty;
        var idx = nombre.LastIndexOf('(');
        return (idx > 0 ? nombre.Substring(0, idx) : nombre).Trim();
    }

    string Js(string? value) => (value ?? string.Empty)
        .Replace("\\", "\\\\")
        .Replace("'", "\\'")
        .Replace("\r", "")
        .Replace("\n", "\\n");
}

@section Styles {
    <link rel="stylesheet" href="~/css/pages/Libros.css" />
    <style>
        /* Etiqueta de campos obligatorios */
        .form-label-req {
            display: block;
            font-size: 0.82rem;
            font-weight: 500;
            margin-bottom: 5px;
            opacity: 0.85;
        }
        .form-label-req .req-star {
            color: #ff4d4f;
            font-weight: 700;
            margin-left: 2px;
        }

        /* Modal de detalle: cuadricula simetrica de 2 columnas */
        #modalDetalle .detalle-libro-grid {
            display: grid;
            grid-template-columns: repeat(2, minmax(0, 1fr));
            gap: 14px;
            margin-bottom: 14px;
        }
        @@media (max-width: 520px) {
            #modalDetalle .detalle-libro-grid {
                grid-template-columns: 1fr;
            }
        }
    </style>
}

<div class="libros-container">

    <div class="page-header">
        <div class="titulo-logo">
            <h1>Gestión de Libros</h1>
        </div>
        <button type="button" class="btn-nuevo" onclick="abrirModalCrear()">
            <img src="~/assets/icons/add_24dp_E3E3E3_FILL0_wght400_GRAD0_opsz24.svg" class="icono-btn icon-white">
            Nuevo Libro
        </button>
    </div>

@if (!Model.Libros.Any())
{
    <div class="alert alert-info">
        No hay libros registrados en el sistema.
    </div>
}
else
{
    var total = Model.Libros.Count();
    var activos = Model.Libros.Count(l => l.Estado);

    var inactivos = total - activos;

    <div class="filtros-barra">
        <div class="filtro-item filtro-buscar">
            <input id="buscador-libro" type="text" class="input-filtro"
                   placeholder="Buscar por título, autor, editorial o estado..."
                   autocomplete="off" />
        </div>
    </div>

<div class="tabla-container">
    <table id="tabla-libro" class="tabla-libros">
        <thead>
            <tr>
                <th>Título</th>
                <th>Autor</th>
                <th>Editorial</th>
                <th>Año de Publicación</th>
                <th>Estado</th>
                <th>Acciones</th>
            </tr>
        </thead>

        <tbody>
        @foreach (var row in Model.Libros)
        {
            var libroToken = Model.LibroTokens.TryGetValue(row.LibroId, out var tk) ? tk : "";
            var autorId = row.AutorId;
            var titulo = row.Titulo;
            var isbn = row.ISBN ?? "";
            var editorial = row.Editorial;
            var genero = row.Genero ?? "";
            var edicion = row.Edicion;
            var añoPublicacion = row.AñoPublicacion;
            var numeroPaginas = row.NumeroPaginas;
            var idioma = row.Idioma ?? "";
            var paisPublicacion = row.PaisPublicacion ?? "";
            var estado = row.Estado;
            var descripcion = row.Descripcion ?? "";
            var autorCompleto = Model.AutoresNombres.TryGetValue(autorId, out var nombreAutorRow)
                ? nombreAutorRow.ToDisplayName()
                : $"Autor #{autorId}";
            var autorSoloNombre = SoloNombreAutor(autorCompleto);

            <tr class="@(!estado ? "fila-inactiva" : "")">

                <td><strong>@titulo</strong></td>

                <td>@autorSoloNombre</td>

                <td>@(editorial ?? "N/A")</td>

                <td>@(añoPublicacion?.ToString() ?? "N/A")</td>

                <td>
                    <span class="estado @(estado ? "activo" : "inactivo")">
                        @(estado ? "Activo" : "Inactivo")
                    </span>
                </td>

<td class="acciones">

    <button class="btn-info"
        onclick="abrirModalDetalle(
            '@Js(autorCompleto)',
            '@Js(titulo)',
            '@Js(isbn)',
            '@Js(editorial)',
            '@Js(genero)',
            '@Js(edicion)',
            '@(añoPublicacion?.ToString() ?? "")',
            '@(numeroPaginas?.ToString() ?? "")',
            '@Js(idioma)',
            '@Js(paisPublicacion)',
            '@Js(descripcion)',
            '@Js(row.FechaRegistro.ToString("o"))',
            '@Js(row.UltimaActualizacion?.ToString("o") ?? "")'
        )">
        Ver más
    </button>

    <button type="button" class="btn-editar"
        onclick="abrirModalEditar(
            '@libroToken',
            '@autorId',
            '@Js(titulo)',
            '@Js(isbn)',
            '@Js(editorial)',
            '@Js(genero)',
            '@Js(edicion)',
            '@(añoPublicacion?.ToString() ?? "")',
            '@(numeroPaginas?.ToString() ?? "")',
            '@Js(idioma)',
            '@Js(paisPublicacion)',
            '@Js(descripcion)',
            '@estado')">
        Editar
    </button>

    @if (estado)
    {
        <button type="button" class="btn-eliminar"
            onclick="abrirModalEliminar('@libroToken')">
            Eliminar
        </button>
    }
    else
    {
        <span class="estado eliminado-label">Eliminado</span>
    }

</td>

            </tr>
        }
        </tbody>
    </table>
</div>

    <div class="estadisticas">
        <div class="stat stat-info">Total libros: @total</div>
        <div class="stat stat-success">Activos: @activos</div>
        <div class="stat stat-secondary">Inactivos: @inactivos</div>
    </div>
}

</div>

<!-- MODAL ELIMINAR -->
<div id="modalEliminar" class="modal">
    <div class="modal-box">
        <div class="modal-icon">
            <img src="~/assets/icons/delete_24dp_E3E3E3_FILL0_wght400_GRAD0_opsz24.svg" class="icono-modal">
        </div>
        <h2>¿Estás seguro de que quieres eliminar este libro?</h2>
        <p>Esta acción no se puede deshacer.</p>
        <form method="post" asp-page-handler="Eliminar">
            @Html.AntiForgeryToken()
            <input type="hidden" id="libroTokenInput" name="token" />
            <div class="modal-buttons">
                <button type="submit" class="btn-danger">Sí, eliminar</button>
                <button type="button" class="btn-secondary" onclick="cerrarModalEliminar()">Cancelar</button>
            </div>
        </form>
    </div>
</div>

<!-- MODAL EDITAR -->
<div id="modalEditar" class="modal">
    <div class="modal-box">
        <div class="modal-icon editar">
            <img src="~/assets/icons/edit_24dp_E3E3E3_FILL0_wght400_GRAD0_opsz24.svg" class="icono-modal">
        </div>
        <h2>Editar libro</h2>
        <p>Modifica la información del libro.</p>

        <form method="post" asp-page-handler="Editar" id="formEditarLibro" novalidate>
            @Html.AntiForgeryToken()
            <input type="hidden" id="editToken" name="token" />
            <input type="hidden" id="editFechaRegistro" name="FechaRegistro" />
            <input type="hidden" id="editEstado" name="Estado" />

            <div id="error-summary-edit" class="text-error-summary" style="display:none;"></div>

            <div class="custom-select-wrapper">
                <label class="form-label-req">Autor <span class="req-star">*</span></label>
                <input type="hidden" id="editAutorId" name="AutorId" />
                <div class="custom-select" id="custom-select-autor-edit">
                    <div class="select-trigger">
                        <input type="text" id="editAutorText" class="select-trigger-input" placeholder="-- Seleccione un autor --" readonly />
                        <svg class="select-arrow" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <polyline points="6 9 12 15 18 9"></polyline>
                        </svg>
                    </div>
                    <div class="select-dropdown">
                        <div class="select-options">
                            @foreach (var autorRow in Model.Autores.OrderBy(autorRow => $"{(autorRow.Nombres ?? "").ToDisplayName()} {(autorRow.Apellidos ?? "").ToDisplayName()}"))
                            {
                                var aId = autorRow.AutorId;
                                var nombres = (autorRow.Nombres ?? "").ToDisplayName();
                                var apellidos = (autorRow.Apellidos ?? "").ToDisplayName();
                                var nacionalidad = autorRow.Nacionalidad;
                                var textoAutor = $"{nombres} {apellidos}" + (!string.IsNullOrWhiteSpace(nacionalidad) ? $" ({nacionalidad})" : "");
                                <div class="option" data-value="@aId">@textoAutor</div>
                            }
                        </div>
                    </div>
                </div>
                <span class="text-error" id="error-edit-AutorId"></span>
            </div>

            <div class="input-group">
                <label class="form-label-req">Título <span class="req-star">*</span></label>
                <input type="text" id="editTituloText" name="Titulo" placeholder="Título del libro" autocomplete="off" spellcheck="false" />
                <span class="text-error" id="error-edit-Titulo"></span>
            </div>

            <div class="custom-select-wrapper">
                <input type="hidden" id="editGeneroHidden" name="Genero" />
                <div class="custom-select custom-select-free" id="custom-select-genero-edit">
                    <div class="select-trigger">
                        <input type="text" id="editGeneroText" class="select-trigger-input" placeholder="Género" />
                        <svg class="select-arrow" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <polyline points="6 9 12 15 18 9"></polyline>
                        </svg>
                    </div>
                    <div class="select-dropdown">
                         <div class="select-options">
                             @foreach (var generoItem in generosSugeridos.OrderBy(x => x))
                             {
                                 <div class="option" data-value="@generoItem">@generoItem</div>
                             }
                         </div>
                    </div>
                </div>
                <span class="text-error" id="error-edit-Genero"></span>
            </div>

            <div class="input-group">
                <input type="text" id="editISBN" name="ISBN" placeholder="ISBN (10 o 13 dígitos)" maxlength="17" />
                <span class="text-error" id="error-edit-ISBN"></span>
            </div>

            <div class="input-group">
                <input type="text" id="editEditorial" name="Editorial" placeholder="Editorial" inputmode="text" />
                <span class="text-error" id="error-edit-Editorial"></span>
            </div>

            <div class="custom-select-wrapper">
                <input type="hidden" id="editEdicion" name="Edicion" />
                <div class="custom-select" id="custom-select-edicion-edit">
                    <div class="select-trigger">
                        <input type="text" id="editEdicionText" class="select-trigger-input" placeholder="-- Seleccione una edición --" />
                        <svg class="select-arrow" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <polyline points="6 9 12 15 18 9"></polyline>
                        </svg>
                    </div>
                    <div class="select-dropdown">
                        <div class="select-options">
                            <div class="option" data-value="1ra Edición">1ra Edición</div>
                            <div class="option" data-value="2da Edición">2da Edición</div>
                        </div>
                    </div>
                </div>
                <span class="text-error" id="error-edit-Edicion"></span>
            </div>

            <div class="input-group">
                <input type="number" id="editAnioPublicacion" name="AñoPublicacion" placeholder="Año (1000-2026)" min="1000" max="2026" />
                <span class="text-error" id="error-edit-AñoPublicacion"></span>
            </div>

            <div class="input-group">
                <input type="number" id="editNumeroPaginas" name="NumeroPaginas" placeholder="Número de páginas" min="1" />
                <span class="text-error" id="error-edit-NumeroPaginas"></span>
            </div>

            <div class="custom-select-wrapper">
                <input type="hidden" id="editIdiomaHidden" name="Idioma" />
                <div class="custom-select" id="custom-select-idioma-edit">
                    <div class="select-trigger">
                        <input type="text" id="editIdiomaText" class="select-trigger-input" placeholder="Idioma" />
                        <svg class="select-arrow" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <polyline points="6 9 12 15 18 9"></polyline>
                        </svg>
                    </div>
                    <div class="select-dropdown">
                        <div class="select-options">
                            <div class="option" data-value="Español">Español</div>
                            <div class="option" data-value="Inglés">Inglés</div>
                            <div class="option" data-value="Chino mandarín">Chino mandarín</div>
                            <div class="option" data-value="Hindi">Hindi</div>
                            <div class="option" data-value="Francés">Francés</div>
                            <div class="option" data-value="Árabe">Árabe</div>
                            <div class="option" data-value="Bengalí">Bengalí</div>
                            <div class="option" data-value="Portugués">Portugués</div>
                            <div class="option" data-value="Ruso">Ruso</div>
                            <div class="option" data-value="Urdu">Urdu</div>
                        </div>
                    </div>
                </div>
                <span class="text-error" id="error-edit-Idioma"></span>
            </div>

            <div class="custom-select-wrapper">
                <input type="hidden" id="editPaisPublicacionHidden" name="PaisPublicacion" />
                <div class="custom-select" id="custom-select-pais-edit">
                    <div class="select-trigger">
                        <input type="text" id="editPaisPublicacionText" class="select-trigger-input" placeholder="País de publicación" />
                        <svg class="select-arrow" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <polyline points="6 9 12 15 18 9"></polyline>
                        </svg>
                    </div>
                    <div class="select-dropdown">
                        <div class="select-options">
                            @foreach (var paisItem in paisesSugeridos.OrderBy(x => x))
                            {
                                <div class="option" data-value="@paisItem">@paisItem</div>
                            }
                        </div>
                    </div>
                </div>
                <span class="text-error" id="error-edit-PaisPublicacion"></span>
            </div>

            <div class="input-group">
                <textarea id="editDescripcion" name="Descripcion" placeholder="Descripción" rows="4"></textarea>
                <span class="text-error" id="error-edit-Descripcion"></span>
            </div>

            <div class="modal-buttons">
                <button type="submit" class="btn-warning">Guardar cambios</button>
                <button type="button" class="btn-secondary" onclick="cerrarModalEditar()">Cancelar</button>
            </div>
        </form>
    </div>
</div>

<div id="modalCrear" class="modal">
    <div class="modal-box">
        <div class="modal-icon crear">
            <img src="~/assets/icons/add_24dp_E3E3E3_FILL0_wght400_GRAD0_opsz24.svg" class="icono-modal">
        </div>
        <h2>Nuevo libro</h2>
        <p>Ingresa la información del libro.</p>

        <form method="post" asp-page-handler="Crear" id="formCrearLibro" novalidate>
            @Html.AntiForgeryToken()

            <div id="error-summary-create" class="text-error-summary" style="display:none;"></div>

            <div class="custom-select-wrapper">
                <label class="form-label-req">Autor <span class="req-star">*</span></label>
                <input type="hidden" id="createAutorId" name="AutorId" />
                <input type="hidden" id="createAutorNuevo" name="NombreAutorNuevo" />
                <div class="custom-select" id="custom-select-autor-create">
                    <div class="select-trigger">
                        <input type="text" id="createAutorText" class="select-trigger-input" placeholder="Seleccione un autor..." />
                        <svg class="select-arrow" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <polyline points="6 9 12 15 18 9"></polyline>
                        </svg>
                    </div>
                    <div class="select-dropdown">
                        <div class="select-options">
                            @foreach (var autorRow in Model.Autores.OrderBy(autorRow => $"{(autorRow.Nombres ?? "").ToDisplayName()} {(autorRow.Apellidos ?? "").ToDisplayName()}"))
                            {
                                if (!autorRow.Estado) continue;
                                var aId = autorRow.AutorId;
                                var nombres = (autorRow.Nombres ?? "").ToDisplayName();
                                var apellidos = (autorRow.Apellidos ?? "").ToDisplayName();
                                var nacionalidad = autorRow.Nacionalidad;
                                var displayText = $"{nombres} {apellidos}{(!string.IsNullOrWhiteSpace(nacionalidad) ? $" ({nacionalidad})" : "")}";
                                <div class="option" data-value="@aId">@displayText</div>
                            }
                        </div>
                    </div>
                </div>
                <span class="text-error" id="error-create-AutorId"></span>
            </div>

            <div class="custom-select-wrapper">
                <label class="form-label-req">Título <span class="req-star">*</span></label>
                <input type="text" id="createTituloText" name="Titulo" placeholder="Título del libro" autocomplete="off" spellcheck="false" />
                <span class="text-error" id="error-create-Titulo"></span>
            </div>

            <div class="custom-select-wrapper">
                <input type="hidden" id="createGeneroHidden" name="Genero" />
                <div class="custom-select custom-select-free" id="custom-select-genero-create">
                    <div class="select-trigger">
                        <input type="text" id="createGeneroText" class="select-trigger-input" placeholder="Género" />
                        <svg class="select-arrow" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <polyline points="6 9 12 15 18 9"></polyline>
                        </svg>
                    </div>
                    <div class="select-dropdown">
                        <div class="select-options">
                            @foreach (var generoItem in generosSugeridos.OrderBy(x => x))
                            {
                                <div class="option" data-value="@generoItem">@generoItem</div>
                            }
                        </div>
                    </div>
                </div>
                <span class="text-error" id="error-create-Genero"></span>
            </div>

            <div class="input-group">
                <input type="text" id="createISBN" name="ISBN" placeholder="ISBN (10 o 13 dígitos)" maxlength="17" />
                <span class="text-error" id="error-create-ISBN"></span>
            </div>

            <div class="input-group">
                <input type="text" id="createEditorial" name="Editorial" placeholder="Editorial" inputmode="text" />
                <span class="text-error" id="error-create-Editorial"></span>
            </div>

            <div class="custom-select-wrapper">
                <input type="hidden" id="createEdicion" name="Edicion" />
                <div class="custom-select" id="custom-select-edicion-create">
                    <div class="select-trigger">
                        <input type="text" id="createEdicionText" class="select-trigger-input" placeholder="-- Seleccione una edición --" />
                        <svg class="select-arrow" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <polyline points="6 9 12 15 18 9"></polyline>
                        </svg>
                    </div>
                    <div class="select-dropdown">
                        <div class="select-options">
                            <div class="option" data-value="1ra Edición">1ra Edición</div>
                            <div class="option" data-value="2da Edición">2da Edición</div>
                        </div>
                    </div>
                </div>
                <span class="text-error" id="error-create-Edicion"></span>
            </div>

            <div class="input-group">
                <input type="number" id="createAnioPublicacion" name="AñoPublicacion" placeholder="Año (1000-2026)" min="1000" max="2026" />
                <span class="text-error" id="error-create-AñoPublicacion"></span>
            </div>

