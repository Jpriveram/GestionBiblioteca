 }

function cerrarModalCrear() {
    document.getElementById("modalCrear").style.display = "none";
}

function enviarFormularioCrearAjax(formulario) {
    const formData = new FormData(formulario);
    const errorSummary = document.getElementById('error-summary-create');

    // Validar campos requeridos en el frontend
    const erroresValidacion = validarCamposCrear();
    if (erroresValidacion.length > 0) {
        mostrarErroresValidacion('create', erroresValidacion);
        return;
    }

    fetch(formulario.action, {
        method: 'POST',
        body: formData,
        headers: {
            'X-Requested-With': 'XMLHttpRequest'
        }
    })
    .then(response => response.json())
    .then(data => {
        if (data.success) {
            cerrarModalCrear();
            location.reload();
        } else {
            mostrarErroresCrear(data.errors);
        }
    })
    .catch(error => {
        console.error('Error en fetch:', error);
        errorSummary.style.display = 'block';
        errorSummary.innerHTML = '<p>Error al procesar la solicitud</p>';
    });
}

function validarCamposCrear() {
    const errores = [];
    
    const autorId = document.getElementById('createAutorId').value.trim();
    const titulo = document.getElementById('createTituloText').value.trim();
    const isbn = document.getElementById('createISBN').value.trim();
    const editorial = document.getElementById('createEditorial').value.trim();
    const numPaginas = document.getElementById('createNumeroPaginas').value.trim();
    const anioPublicacion = document.getElementById('createAnioPublicacion').value.trim();
    
    if (!autorId) {
        errores.push({ campo: 'AutorId', mensaje: 'El autor es requerido' });
    }
    
    if (!titulo) {
        errores.push({ campo: 'Titulo', mensaje: 'El título es requerido' });
    }

    if (isbn && (isbn.length < 10 || isbn.length > 13)) {
        errores.push({ campo: 'ISBN', mensaje: 'El ISBN debe tener entre 10 y 13 dígitos' });
    }

    if (editorial && editorial.length > 200) {
        errores.push({ campo: 'Editorial', mensaje: 'La editorial no puede exceder 200 caracteres' });
    }

    if (numPaginas && (isNaN(numPaginas) || numPaginas < 1)) {
        errores.push({ campo: 'NumeroPaginas', mensaje: 'El número de páginas debe ser mayor a 0' });
    }

    if (anioPublicacion) {
        const anio = parseInt(anioPublicacion, 10);
        if (isNaN(anio) || anio < 1000 || anio > new Date().getFullYear()) {
            errores.push({ campo: 'AñoPublicacion', mensaje: 'El año debe estar entre 1000 y ' + new Date().getFullYear() });
        }
    }
    
    return errores;
}

function limpiarErrores(tipo, campos) {
    campos.forEach(campo => {
        const elemento = document.getElementById(`error-${tipo}-${campo}`);
        if (elemento) {
            elemento.textContent = '';
            elemento.style.display = 'none';
        }
    });
    const summary = document.getElementById(`error-summary-${tipo}`);
    if (summary) {
        summary.innerHTML = '';
        summary.style.display = 'none';
    }
}

function mostrarErroresValidacion(tipo, errores) {
    limpiarErrores(tipo, ['AutorId', 'Titulo', 'ISBN', 'Editorial', 'Genero', 'Edicion', 'AñoPublicacion', 'NumeroPaginas', 'Idioma', 'PaisPublicacion', 'Descripcion']);
    
    errores.forEach(error => {
        const elementoError = document.getElementById(`error-${tipo}-${error.campo}`);
        if (elementoError) {
            elementoError.textContent = error.mensaje;
            elementoError.style.display = 'block';
        }
    });
}

function enviarFormularioEditarAjax(formulario) {
    const formData = new FormData(formulario);
    const errorSummary = document.getElementById('error-summary-edit');

    // Validar campos requeridos en el frontend
    const erroresValidacion = validarCamposEditar();
    if (erroresValidacion.length > 0) {
        mostrarErroresValidacion('edit', erroresValidacion);
        return;
    }

    fetch(formulario.action, {
        method: 'POST',
        body: formData,
        headers: {
            'X-Requested-With': 'XMLHttpRequest'
        }
    })
    .then(response => response.json())
    .then(data => {
        if (data.success) {
            cerrarModalEditar();
            location.reload();
        } else {
            mostrarErroresEditar(data.errors);
        }
    })
    .catch(error => {
        console.error('Error:', error);
        errorSummary.style.display = 'block';
        errorSummary.innerHTML = '<p>Error al procesar la solicitud</p>';
    });
}

function validarCamposEditar() {
    const errores = [];
    
    const autorId = document.getElementById('editAutorId').value.trim();
    const titulo = document.getElementById('editTituloText').value.trim();
    const isbn = document.getElementById('editISBN').value.trim();
    const editorial = document.getElementById('editEditorial').value.trim();
    const numPaginas = document.getElementById('editNumeroPaginas').value.trim();
    const anioPublicacion = document.getElementById('editAnioPublicacion').value.trim();
    
    if (!autorId) {
        errores.push({ campo: 'AutorId', mensaje: 'El autor es requerido' });
    }
    
    if (!titulo) {
        errores.push({ campo: 'Titulo', mensaje: 'El título es requerido' });
    }

    if (isbn && (isbn.length < 10 || isbn.length > 13)) {
        errores.push({ campo: 'ISBN', mensaje: 'El ISBN debe tener entre 10 y 13 dígitos' });
    }

    if (editorial && editorial.length > 200) {
        errores.push({ campo: 'Editorial', mensaje: 'La editorial no puede exceder 200 caracteres' });
    }

    if (numPaginas && (isNaN(numPaginas) || numPaginas < 1)) {
        errores.push({ campo: 'NumeroPaginas', mensaje: 'El número de páginas debe ser mayor a 0' });
    }

    if (anioPublicacion) {
        const anio = parseInt(anioPublicacion, 10);
        if (isNaN(anio) || anio < 1000 || anio > new Date().getFullYear()) {
            errores.push({ campo: 'AñoPublicacion', mensaje: 'El año debe estar entre 1000 y ' + new Date().getFullYear() });
        }
    }
    
    return errores;
}

function mostrarErroresCrear(errors) {
    console.log('Errores recibidos:', errors);
    
    limpiarErrores('create', ['AutorId', 'Titulo', 'ISBN', 'Editorial', 'Genero', 'Edicion', 'AñoPublicacion', 'NumeroPaginas', 'Idioma', 'PaisPublicacion', 'Descripcion']);

    let tieneErrores = false;

    Object.keys(errors).forEach(campo => {
        const mensajeArray = errors[campo];
        if (!Array.isArray(mensajeArray) || mensajeArray.length === 0) return;

        const mensajeError = mensajeArray[0];
        if (!mensajeError) return;

        // Procesar el nombre del campo
        let nombreCampo = campo
            .replace('Libro.', '')
            .replace('A\uFFFDDoPublicacion', 'AñoPublicacion')
            .trim();
        
        console.log(`Campo procesado: "${campo}" -> "${nombreCampo}"`);

        // Mapeo de errores generales a campos específicos basado en el mensaje
        if (!nombreCampo || nombreCampo === '') {
            console.log('Error general:', mensajeError);
            
            // Intentar mapear basándose en el contenido del mensaje
            const mensajeLower = mensajeError.toLowerCase();
            
            if (mensajeLower.includes('isbn') || mensajeLower.includes('10') || mensajeLower.includes('13')) {
                const elementoError = document.getElementById('error-create-ISBN');
                if (elementoError) {
                    elementoError.textContent = mensajeError;
                    elementoError.style.display = 'block';
                    tieneErrores = true;
                }
            } else if (mensajeLower.includes('páginas') || mensajeLower.includes('paginas')) {
                const elementoError = document.getElementById('error-create-NumeroPaginas');
                if (elementoError) {
                    elementoError.textContent = mensajeError;
                    elementoError.style.display = 'block';
                    tieneErrores = true;
                }
            } else if (mensajeLower.includes('publicación') || mensajeLower.includes('publicacion') || mensajeLower.includes('año') || mensajeLower.includes('anio')) {
                const elementoError = document.getElementById('error-create-AñoPublicacion');
                if (elementoError) {
                    elementoError.textContent = mensajeError;
                    elementoError.style.display = 'block';
                    tieneErrores = true;
                }
            } else if (mensajeLower.includes('válido') || mensajeLower.includes('valido')) {
                // Error genérico de validación, mostrar en el primero disponible
                const elementoError = document.getElementById('error-create-ISBN');
                if (elementoError) {
                    elementoError.textContent = mensajeError;
                    elementoError.style.display = 'block';
                    tieneErrores = true;
                }
            }
            return;
        }

        const elementoError = document.getElementById(`error-create-${nombreCampo}`);

        if (elementoError) {
            elementoError.textContent = mensajeError;
            elementoError.style.display = 'block';
            console.log(`Error mostrado para ${nombreCampo}: ${mensajeError}`);
            tieneErrores = true;
        } else {
            console.log(`No se encontró elemento para: error-create-${nombreCampo}`);
        }
    });

    if (!tieneErrores && Object.keys(errors).length > 0) {
        console.log('Errores recibidos pero no se pudieron mapear a campos', errors);
    }
}

