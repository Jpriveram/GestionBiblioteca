function mostrarErroresCrear(errors) {
    const errorSummary = document.getElementById('error-summary-create');

    limpiarErrores('create', ['AutorId', 'Titulo', 'ISBN', 'Editorial', 'Genero', 'Edicion', 'AñoPublicacion', 'NumeroPaginas', 'Idioma', 'PaisPublicacion', 'Descripcion']);

    let hayErrores = false;
    let mensajeResumen = '<strong>Errores encontrados:</strong><ul>';

    Object.keys(errors).forEach(campo => {
        const mensajeArray = errors[campo];
        if (!Array.isArray(mensajeArray) || mensajeArray.length === 0) return;

        const mensajeError = mensajeArray[0];
        if (!mensajeError) return;

        const nombreCampo = campo.replace('Libro.', '').replace('A�oPublicacion', 'AñoPublicacion');
        const elementoError = document.getElementById(`error-create-${nombreCampo}`);

        if (elementoError) {
            elementoError.textContent = mensajeError;
            elementoError.style.display = 'block';
        }

        hayErrores = true;
        mensajeResumen += `<li>${mensajeError}</li>`;
    });

    if (hayErrores) {
        mensajeResumen += '</ul>';
        errorSummary.innerHTML = mensajeResumen;
        errorSummary.style.display = 'block';
    }
}

