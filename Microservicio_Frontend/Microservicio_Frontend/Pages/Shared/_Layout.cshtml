@using Frontend.Helpers
@using Microsoft.AspNetCore.Http
@{
    var nombreUsuarioSesion = Context.Session.GetString(SessionKeys.NombreUsuario);
    var rolSesion = Context.Session.GetString(SessionKeys.Rol);
    var haySesion = !string.IsNullOrWhiteSpace(Context.Session.GetString(SessionKeys.UsuarioId));
    var esAdmin = string.Equals(rolSesion, "Admin", StringComparison.OrdinalIgnoreCase);
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - gestion_bibliotecaria</title>

    <script type="importmap"></script>

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/gestion_bibliotecaria.styles.css" asp-append-version="true" />

    @await RenderSectionAsync("Styles", required: false)
</head>
<body>
<header>
    <nav class="navbar navbar-expand-sm navbar-toggleable-sm navbar-light bg-white border-bottom box-shadow mb-3">
        <div class="container">

            <!-- LOGO -->
            <a class="navbar-brand d-flex align-items-center" href="/">
                <img src="~/assets/images/blackLogo.png" height="60" width="100" class="me-2">
                @* gestion_bibliotecaria *@
            </a>

            <!-- BOTON MOBILE -->
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse"
                    data-bs-target=".navbar-collapse"
                    aria-controls="navbarSupportedContent"
                    aria-expanded="false"
                    aria-label="Toggle navigation">

                <img src="~/assets/icons/menu_24dp_E3E3E3_FILL0_wght400_GRAD0_opsz24.svg" width="24">

            </button>

            <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">

                <ul class="navbar-nav flex-grow-1">
                    @if (haySesion)
                    {
                        <!-- HOME -->
                        <li class="nav-item">
                            <a class="nav-link text-dark d-flex align-items-center gap-2" href="/">
                                <img src="~/assets/icons/home_24dp_E3E3E3_FILL0_wght400_GRAD0_opsz24.svg" width="20">
                                Home
                            </a>
                        </li>

                        <!-- EJEMPLAR -->
                        <li class="nav-item">
                            <a class="nav-link text-dark d-flex align-items-center gap-2" href="/Ejemplar">
                                <img src="~/assets/icons/inventory_2_24dp_E3E3E3_FILL0_wght400_GRAD0_opsz24.svg" width="20">
                                Ejemplar
                            </a>
                        </li>

                        <!-- LIBROS -->
                        <li class="nav-item">
                            <a class="nav-link text-dark d-flex align-items-center gap-2" href="/Libro">
                                <img src="~/assets/icons/library_books_24dp_E3E3E3_FILL0_wght400_GRAD0_opsz24.svg" width="20">
                                Libros
                            </a>
                        </li>

                        <!-- AUTORES -->
                        <li class="nav-item">
                            <a class="nav-link text-dark d-flex align-items-center gap-2" href="/Autor">
                                <img src="~/assets/icons/person_24dp_E3E3E3_FILL0_wght400_GRAD0_opsz24.svg" width="20">
                                Autores
                            </a>
                        </li>

                        <!-- PRESTAMOS -->
                        <li class="nav-item">
                            <a class="nav-link text-dark d-flex align-items-center gap-2" href="/Prestamo">
                                <img src="~/assets/icons/history_edu_24dp_E3E3E3_FILL0_wght400_GRAD0_opsz24.svg" width="20">
                                Préstamos
                            </a>
                        </li>

                        @if (esAdmin)
                        {
                            <li class="nav-item">
                                <a class="nav-link text-dark d-flex align-items-center gap-2" href="/Usuarios">
                                    <img src="~/assets/icons/groups_24dp_E3E3E3_FILL0_wght400_GRAD0_opsz24.svg" width="20">
                                    Usuarios
                                </a>
                            </li>
                        }
                    }
                </ul>

                <ul class="navbar-nav">
                    @if (!haySesion)
                    {
                        <li class="nav-item">
                            <a class="nav-link text-dark d-flex align-items-center gap-2" href="/?login=1">
                                <img src="~/assets/icons/person_24dp_E3E3E3_FILL0_wght400_GRAD0_opsz24.svg" width="20">
                                Iniciar sesion
                            </a>
                        </li>
                    }
                    else
                    {
                        <li class="nav-item dropdown">
                            <a class="nav-link nav-btn dropdown-toggle d-flex align-items-center gap-2"
                                href="#"
                                role="button"
                                data-bs-toggle="dropdown"
                                aria-expanded="false">
                                <img src="~/assets/icons/person_24dp_E3E3E3_FILL0_wght400_GRAD0_opsz24.svg" width="20">
                                @nombreUsuarioSesion.ToDisplayName()
                            </a>

                            <ul class="dropdown-menu dropdown-menu-end custom-dropdown-menu">
                                <li>
                                    <form method="post" action="/Login?handler=Logout">
                                        @Html.AntiForgeryToken()
                                        <button type="submit" class="dropdown-item custom-dropdown-item">
                                            Cerrar sesion
                                        </button>
                                    </form>
                                </li>
                            </ul>
                        </li>
                    }
                </ul>

            </div>
        </div>
    </nav>
</header>
    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="border-top footer text-muted">
        <div class="container">
            &copy; 2026 - gestion_bibliotecaria - <a href="/Privacy">Privacy</a>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
