@using Frontend.Helpers
@using Microsoft.AspNetCore.Http
@{
    var nombreUsuarioSesion = Context.Session.GetString(SessionKeys.NombreUsuario);
    var rolSesion = Context.Session.GetString(SessionKeys.Rol);
    var haySesion = !string.IsNullOrWhiteSpace(Context.Session.GetString(SessionKeys.UsuarioId));
    var debeCambiarPassword = string.Equals(Context.Session.GetString(SessionKeys.DebeCambiarPassword), "true", StringComparison.OrdinalIgnoreCase);
    var changePasswordError = TempData["ChangePasswordError"]?.ToString();
    var changePasswordOk = TempData["ChangePasswordOk"]?.ToString();
    var changePasswordOkVisible = !string.IsNullOrWhiteSpace(changePasswordOk);
    var esAdmin = string.Equals(rolSesion, "Admin", StringComparison.OrdinalIgnoreCase);
    var esBibliotecario = string.Equals(rolSesion, "Bibliotecario", StringComparison.OrdinalIgnoreCase);
    var esLector = string.Equals(rolSesion, "Lector", StringComparison.OrdinalIgnoreCase);
}

<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <script type="importmap"></script>

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
