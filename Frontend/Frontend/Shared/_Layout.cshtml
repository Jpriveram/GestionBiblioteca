</header>

<main class="container-fluid main-content">
    @RenderBody()
</main>

@if (!haySesion)
{
    <div id="modalLogin" class="custom-modal">
        <div class="modal-box modal-login-box">

            <div class="modal-icon login">
                <img src="~/assets/icons/person_24dp_E3E3E3_FILL0_wght400_GRAD0_opsz24.svg"
                    class="icono-modal" />
            </div>

            <h2>Iniciar sesión</h2>
            <p>Ingresa tus credenciales para acceder al sistema.</p>

                <form method="post" action="/Login" id="formLoginModal" autocomplete="off" novalidate>
                    @Html.AntiForgeryToken()

                    <div id="mensajeLoginModal" class="text-error-summary" style="display:none;"></div>

                    @if (TempData["LoginError"] != null)
                    {
                        <div id="mensajeLoginServidor" class="text-error-summary">
                            @TempData["LoginError"]
                        </div>
                    }

                    <input type="text"
                            name="NombreUsuario"
                            id="loginNombreUsuario"
                            class="input-form"
                            placeholder="Nombre de usuario" />

                    <div class="password-wrapper">
                        <input type="password"
                                name="Password"
                                id="loginPassword"
                                class="input-form password-input"
                                placeholder="Contraseña" />

                        <button type="button"
                                class="toggle-password-btn"
                                onclick="togglePasswordLogin()"
                                aria-label="Mostrar u ocultar contraseña">
                            <img id="togglePasswordIcon"
                                src="~/assets/icons/visibility_24dp_E3E3E3_FILL0_wght400_GRAD0_opsz24.svg"
                                alt="Ver contraseña" />
                        </button>
                    </div>

                    <div class="modal-buttons">
                        <button type="submit" class="btn-login-modal">
                            Ingresar
                        </button>

                        <button type="button"
                                class="btn-secondary"
                                onclick="cerrarModalLogin()">
                            Cancelar
                        </button>
                    </div>
                </form>

        </div>
    </div>
}

@if (haySesion)
{
    <div id="modalCambiarPassword" class="custom-modal">
        <div class="modal-box modal-login-box">
            <button type="button"
                    class="modal-close-btn"
                    onclick="cerrarModalCambiarPassword()"
                    aria-label="Cerrar modal de cambio de contraseña">&times;</button>

            <div class="modal-icon login">
                <img src="~/assets/icons/privacy_tip_24dp_E3E3E3_FILL0_wght400_GRAD0_opsz24.svg"
                     class="icono-modal" />
            </div>

            <h2>Cambiar contraseña</h2>
            <p>
                @if (debeCambiarPassword)
                {
                    @:Primer inicio detectado. Debes cambiar tu contraseña para continuar.
                }
                else
                {
                    @:Ingresa tu contraseña actual y define una nueva contraseña segura.
                }
            </p>

            <form method="post" action="/Login?handler=CambiarPasswordModal" id="formCambiarPasswordModal" autocomplete="off" novalidate>
                @Html.AntiForgeryToken()
                <input type="hidden" name="returnUrl" value="@(Context.Request.Path + Context.Request.QueryString)" />

                <div id="mensajeCambiarPasswordModal" class="text-error-summary" style="display:none;"></div>

                @if (!string.IsNullOrWhiteSpace(changePasswordError))
                {
                    <div id="mensajeCambiarPasswordServidor" class="text-error-summary">
                        @changePasswordError
                    </div>
                }

                                    <div class="password-wrapper">
                                            <input type="password"
                                                    name="passwordActualModal"
                                                    id="passwordActualModal"
                                                    class="input-form password-input"
                                                    placeholder="Contraseña actual"
                                                    required />

                                            <button type="button"
                                                class="toggle-password-btn"
                                                onclick="togglePasswordField('passwordActualModal', 'togglePasswordActualModalIcon')"
                                                aria-label="Mostrar u ocultar contraseña actual">
                                             <img id="togglePasswordActualModalIcon"
                                                 src="~/assets/icons/visibility_24dp_E3E3E3_FILL0_wght400_GRAD0_opsz24.svg"
                                                 alt="Ver contraseña" />
                                            </button>
                                    </div>
                                    <div id="errorPasswordActualModal" class="field-error-message" style="display:none;"></div>

                                    <div class="password-wrapper">
                                            <input type="password"
                                                    name="passwordNuevaModal"
                                                    id="passwordNuevaModal"
                                                    class="input-form password-input"
                                                    placeholder="Nueva contraseña"
                                                    required disabled />

                                            <button type="button"
                                                class="toggle-password-btn"
                                                onclick="togglePasswordField('passwordNuevaModal', 'togglePasswordNuevaModalIcon')"
                                                aria-label="Mostrar u ocultar nueva contraseña">
                                             <img id="togglePasswordNuevaModalIcon"
                                                 src="~/assets/icons/visibility_24dp_E3E3E3_FILL0_wght400_GRAD0_opsz24.svg"
                                                 alt="Ver contraseña" />
                                            </button>
                                    </div>
                                    <div id="errorPasswordNuevaModal" class="field-error-message" style="display:none;"></div>

                                    <div class="password-wrapper">
                                            <input type="password"
                                                    name="passwordConfirmacionModal"
                                                    id="passwordConfirmacionModal"
                                                    class="input-form password-input"
                                                    placeholder="Confirmar nueva contraseña"
                                                    required disabled />

                                            <button type="button"
                                                class="toggle-password-btn"
                                                onclick="togglePasswordField('passwordConfirmacionModal', 'togglePasswordConfirmacionModalIcon')"
                                                aria-label="Mostrar u ocultar confirmación de contraseña">
                                             <img id="togglePasswordConfirmacionModalIcon"
                                                 src="~/assets/icons/visibility_24dp_E3E3E3_FILL0_wght400_GRAD0_opsz24.svg"
                                                 alt="Ver contraseña" />
                                            </button>
                                    </div>
                                    <div id="errorPasswordConfirmacionModal" class="field-error-message" style="display:none;"></div>

                                <div class="modal-buttons" style="margin-top:12px;">
                                        <button type="submit" id="btnActualizarPasswordModal" class="btn-login-modal" disabled>Actualizar</button>

                    @if (!debeCambiarPassword)
                    {
                        <button type="button" class="btn-secondary" onclick="cerrarModalCambiarPassword()">Cancelar</button>
                    }
                </div>
            </form>
        </div>
    </div>
}

@if (changePasswordOkVisible)
{
    <div id="modalCambioPasswordExito" class="custom-modal">
        <div class="modal-box modal-login-box">
            <div class="modal-icon login">
